# Overlayr configuration
# Copy to .env (or set as environment variables) — all optional.

# Port the server listens on
PORT=5337

# Password for the admin dashboard. CHANGE THIS before deploying publicly.
ADMIN_PASSWORD=admin

# Where the SQLite database + uploaded assets live (defaults to ./data)
# DATA_DIR=/var/lib/overlayr

# Base URL used when generating OBS Browser Source / webhook links in the
# dashboard (defaults to the request's own host). Set this if you're behind
# a reverse proxy with a different public hostname.
# BASE_URL=https://overlays.example.com
